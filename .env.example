# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Override the Gemini model name if the default becomes deprecated.
GEMINI_MODEL=gemini-2.0-flash

# Optional Fallback API Configurations
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=aiip

# Operational & Logging Configuration
LOG_LEVEL=INFO
ENABLE_JSON_LOGGING=false

# Crawler Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30


# Google Sheets Integration (Optional)
GOOGLE_SHEETS_CREDENTIALS_PATH=google_sheets_credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here